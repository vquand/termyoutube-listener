import {
    Button, LineEdit, ListView, ScrollView, VerticalBox, HorizontalBox,
    GridBox, GroupBox, ComboBox, Slider, ProgressIndicator, StandardButton
} from "std-widgets.slint";

export struct TrackRow {
    id: string,
    title: string,
    uploader: string,
    duration: string,
    platform-glyph: string,
    depth: string,
    is-playing: bool,
}

export struct LibraryRow {
    title: string,
    count-label: string,
    duration-label: string,
    favorite: bool,
    glyph: string,
    is-active: bool,
    is-unsaved: bool,
}

component IconButton inherits Rectangle {
    in property <string> label;
    in property <bool> primary: false;
    in property <length> button-width: 0px;
    callback clicked();
    width: button-width > 0px ? button-width : text.preferred-width + 22px;
    height: 28px;
    border-radius: 6px;
    background: ta.has-hover
        ? (primary ? #7aa2f7 : #2a2c3e)
        : (primary ? #5d80d8 : #1f2030);
    border-width: 1px;
    border-color: primary ? #7aa2f7 : #3a3c52;
    animate background { duration: 80ms; }
    text := Text {
        text: label;
        color: primary ? #0e1018 : #c0caf5;
        font-size: 12px;
        font-weight: primary ? 600 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component TabButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();
    height: 34px;
    border-radius: 6px;
    background: selected ? #2c3045 : (ta.has-hover ? #20222f : transparent);
    animate background { duration: 80ms; }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        Text {
            text: label;
            color: selected ? #c0caf5 : #6c7393;
            font-size: 13px;
            font-weight: selected ? 600 : 500;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component TrackListRow inherits Rectangle {
    in property <TrackRow> item;
    in property <bool> selected;
    in property <bool> show-add: false;
    in property <bool> show-remove: false;
    in property <bool> show-copy: false;
    callback select();
    callback play();
    callback add();
    callback remove();
    callback copy-url();
    height: 32px;
    border-radius: 4px;
    background: selected
        ? #2c3045
        : (ta.has-hover ? #1f2030 : transparent);
    animate background { duration: 60ms; }
    ta := TouchArea {
        clicked => { root.select(); }
        double-clicked => { root.play(); }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        Rectangle {
            horizontal-stretch: 1;
            height: parent.height;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: root.item.is-playing ? "▶" : " ";
                    color: #9ece6a;
                    width: 14px;
                    vertical-alignment: center;
                    font-size: 13px;
                }
                Text {
                    text: root.item.duration;
                    color: #6c7393;
                    width: 52px;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
                Text {
                    text: root.item.platform-glyph;
                    color: #bb9af7;
                    width: 16px;
                    font-size: 12px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.item.depth;
                    color: #565b75;
                    width: 28px;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.item.title;
                    color: #c0caf5;
                    font-size: 13px;
                    font-weight: 500;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
                Text {
                    text: root.item.uploader;
                    color: #565b75;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                    min-width: 120px;
                    max-width: 220px;
                }
            }
        }
        HorizontalLayout {
            spacing: 4px;
            height: 24px;
            IconButton {
                label: "▶";
                button-width: 30px;
                primary: selected;
                clicked => { root.play(); }
            }
            if root.show-add: IconButton {
                label: "+";
                button-width: 30px;
                clicked => { root.add(); }
            }
            if root.show-copy: IconButton {
                label: "URL";
                button-width: 42px;
                clicked => { root.copy-url(); }
            }
            if root.show-remove: IconButton {
                label: "×";
                button-width: 30px;
                clicked => { root.remove(); }
            }
        }
    }
}

component LibraryListRow inherits Rectangle {
    in property <LibraryRow> item;
    in property <bool> selected;
    callback select();
    callback activate();
    callback toggle-fav();
    callback remove();
    height: 34px;
    border-radius: 4px;
    background: selected
        ? #2c3045
        : (ta.has-hover ? #1f2030 : transparent);
    animate background { duration: 60ms; }
    ta := TouchArea {
        clicked => { root.select(); }
        double-clicked => { root.activate(); }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        Rectangle {
            horizontal-stretch: 1;
            height: parent.height;
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: root.item.is-active ? "▶" : " ";
                    color: #9ece6a;
                    width: 14px;
                    vertical-alignment: center;
                    font-size: 13px;
                }
                Text {
                    text: root.item.is-unsaved ? " " : (root.item.favorite ? "★" : "☆");
                    color: root.item.favorite ? #e0af68 : #565b75;
                    width: 22px;
                    font-size: 14px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.item.glyph;
                    color: root.item.is-unsaved ? #e0af68 : #bb9af7;
                    width: 16px;
                    font-size: 12px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.item.title;
                    color: root.item.is-unsaved ? #e0af68 : #c0caf5;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
                Text {
                    text: root.item.count-label;
                    color: #565b75;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                    min-width: 90px;
                    max-width: 120px;
                }
                Text {
                    text: root.item.duration-label;
                    color: #565b75;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                    width: 60px;
                }
            }
        }
        HorizontalLayout {
            spacing: 4px;
            height: 24px;
            IconButton {
                label: "Open";
                button-width: 48px;
                primary: selected;
                clicked => { root.activate(); }
            }
            if !root.item.is-unsaved: IconButton {
                label: root.item.favorite ? "★" : "☆";
                button-width: 30px;
                clicked => { root.toggle-fav(); }
            }
            if !root.item.is-unsaved: IconButton {
                label: "×";
                button-width: 30px;
                clicked => { root.remove(); }
            }
        }
    }
}

component SearchBar inherits Rectangle {
    in-out property <string> search-text;
    in-out property <string> filter-chip;
    callback submit-search(string, string);

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 6px;
        alignment: center;

        if root.filter-chip != "": Text {
            text: " ";
            height: 24px;
            vertical-alignment: center;
            Rectangle {
                height: 24px;
                border-radius: 12px;
                background: root.filter-chip == "youtube"
                    ? #e06c75
                    : (root.filter-chip == "bilibili"
                        ? #bb9af7
                        : #9ece6a);
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 4px;
                    spacing: 4px;
                    Text {
                        text: root.filter-chip == "youtube"
                            ? "YouTube"
                            : (root.filter-chip == "bilibili"
                                ? "Bilibili"
                                : "Local");
                        color: #0e1018;
                        font-size: 11px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "  ";
                        vertical-alignment: center;
                        width: 20px;
                        horizontal-alignment: center;
                        Rectangle {
                            width: 20px;
                            height: 20px;
                            border-radius: 10px;
                            background: #ffffff33;
                            y: (parent.height - self.height) / 2;
                            Text {
                                text: "x";
                                color: #0e1018;
                                font-size: 10px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                clicked => {
                                    root.filter-chip = "";
                                }
                            }
                        }
                    }
                }
            }
        }

        text-input := LineEdit {
            text: root.search-text;
            font-size: 14px;
            placeholder-text: root.filter-chip == "youtube"
                ? "Search YouTube..."
                : (root.filter-chip == "bilibili"
                    ? "Search Bilibili..."
                    : (root.filter-chip == "local"
                        ? "Search local..."
                        : "Search YouTube / Bilibili / Local (Y=YT, B=Bili, H=Local)"));
            horizontal-stretch: 1;
            accepted => {
                if (self.text == "y" || self.text == "Y") {
                    root.filter-chip = "youtube";
                    self.text = "";
                } else if (self.text == "b" || self.text == "B") {
                    root.filter-chip = "bilibili";
                    self.text = "";
                } else if (self.text == "h" || self.text == "H") {
                    root.filter-chip = "local";
                    self.text = "";
                } else if (self.text != "") {
                    let prefix = root.filter-chip == "youtube"
                        ? "#Y "
                        : (root.filter-chip == "bilibili"
                            ? "#B "
                            : (root.filter-chip == "local"
                                ? "#H "
                                : ""));
                    root.submit-search(self.text, root.filter-chip);
                    self.text = "";
                    root.filter-chip = "";
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "ytmtui";
    preferred-width: 1180px;
    preferred-height: 760px;
    min-width: 820px;
    min-height: 520px;
    background: #1a1b26;
    in-out property <string> ui-font-family: "";
    default-font-family: ui-font-family;

    in property <[TrackRow]> results;
    in property <[TrackRow]> tracks;
    in property <[TrackRow]> local-tracks;
    in property <[LibraryRow]> library-rows;

    in property <string> status-text;
    in property <int> active-tab;
    in property <int> results-count;
    in property <int> tracks-count;
    in property <int> local-count;
    in property <int> library-count;
    in property <string> active-playlist-title;
    in property <bool> is-searching;
    in property <bool> is-loading-playlist;
    in property <bool> is-scanning-local;

    in property <string> current-title;
    in property <string> current-uploader;
    in property <string> current-source-label;
    in property <string> position-str;
    in property <string> duration-str;
    in property <float> playback-ratio;
    in property <bool> is-paused;
    in property <bool> has-current;

    in property <bool> show-captions;
    in property <string> caption-text;
    in property <string> caption-status-label;

    in property <int> volume;
    in property <string> loop-mode-label;
    in property <bool> shuffle-on;
    in property <string> device-name;

    in property <bool> show-help;
    in property <bool> show-params;
    in property <bool> show-nerd;
    in-out property <bool> show-save-dialog;
    in-out property <string> save-dialog-default;
    in-out property <string> search-text: "";
    in-out property <string> filter-chip: "";
    in-out property <bool> show-file-dialog: false;
    in-out property <bool> show-playlist-url-dialog: false;
    in property <string> ytmtui-version;
    in property <string> mpv-version;
    in property <string> ytdlp-version;
    in property <string> cpu-summary;
    in property <string> ram-summary;
    in property <string> codec-label;
    in property <string> bitrate-label;
    in property <string> samplerate-label;
    in property <string> channels-label;
    in property <string> device-detail;
    in property <string> sprite-name;
    in property <string> sprite-preview;
    in property <int> sprite-index;
    in property <int> sprite-total;
    in property <string> caption-lang;
    in property <int> caption-lang-index;
    in property <int> caption-lang-total;

    in property <int> results-selected;
    in property <int> tracks-selected;
    in property <int> local-selected;
    in property <int> library-selected;

    callback submit-search(string, string);
    callback open-file(string);
    callback browse-file();
    callback open-playlist-url(string);
    callback save-playlist(string);
    callback select-result(int);
    callback select-track(int);
    callback select-local(int);
    callback select-library-item(int);
    callback play-result(int);
    callback play-track(int);
    callback play-local(int);
    callback add-result-to-playlist(int);
    callback add-local-to-playlist(int);
    callback remove-track(int);
    callback activate-library-item(int);
    callback toggle-favorite(int);
    callback remove-library-entry(int);
    callback toggle-pause();
    callback next-track();
    callback prev-track();
    callback seek(float);
    callback seek-absolute(float);
    callback set-volume(float);
    callback set-tab(int);
    callback cycle-loop();
    callback toggle-shuffle();
    callback toggle-captions();
    callback toggle-nerd();
    callback toggle-help();
    callback toggle-params();
    callback cycle-sprite(int);
    callback cycle-caption-lang(int);
    callback yank-url();
    callback quit();

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            background: #16171f;
            height: 56px;
            border-width: 0px;
            HorizontalLayout {
                padding: 10px;
                spacing: 8px;
                SearchBar {
                    search-text <=> root.search-text;
                    filter-chip <=> root.filter-chip;
                    horizontal-stretch: 1;
                    submit-search(q, chip) => {
                        root.submit-search(q, chip);
                    }
                }
                IconButton {
                    label: "Open";
                    button-width: 56px;
                    clicked => { root.show-file-dialog = !root.show-file-dialog; }
                }
                IconButton {
                    label: "Playlist";
                    button-width: 80px;
                    clicked => { root.show-playlist-url-dialog = !root.show-playlist-url-dialog; }
                }
                IconButton {
                    label: "⚙";
                    button-width: 34px;
                    clicked => { root.toggle-params(); }
                }
                IconButton {
                    label: "?";
                    button-width: 34px;
                    clicked => { root.toggle-help(); }
                }
            }
        }

        Rectangle {
            background: #1a1b26;
            height: 44px;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 5px;
                padding-bottom: 5px;
                spacing: 6px;
                TabButton {
                    label: "Results (" + root.results-count + ")"
                        + (root.is-searching ? "  …" : "");
                    selected: root.active-tab == 0;
                    clicked => { root.set-tab(0); }
                }
                TabButton {
                    label: "Library (" + root.library-count + ")";
                    selected: root.active-tab == 1;
                    clicked => { root.set-tab(1); }
                }
                TabButton {
                    label: "Local (" + root.local-count + ")"
                        + (root.is-scanning-local ? "  …" : "");
                    selected: root.active-tab == 2;
                    clicked => { root.set-tab(2); }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        Rectangle {
            background: #1a1b26;
            vertical-stretch: 1;
            border-width: 0px;
            VerticalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 4px;
                padding-bottom: 4px;

                if root.active-tab == 0: Rectangle {
                    background: #1f2030;
                    border-radius: 8px;
                    VerticalLayout {
                        padding: 6px;
                        HorizontalLayout {
                            height: 34px;
                            spacing: 8px;
                            Text {
                                text: root.is-searching
                                    ? "Search results · loading"
                                    : "Search results · " + root.results-count + " tracks";
                                color: #6c7393;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                        ListView {
                            for r[i] in root.results: TrackListRow {
                                item: r;
                                selected: i == root.results-selected;
                                show-add: true;
                                show-copy: true;
                                select => { root.select-result(i); }
                                play => { root.play-result(i); }
                                add => { root.add-result-to-playlist(i); }
                                copy-url => {
                                    root.select-result(i);
                                    root.yank-url();
                                }
                            }
                        }
                        if root.results.length == 0: Text {
                            text: root.is-searching
                                ? "Searching…"
                                : "No results yet. Type a query in the search box above.";
                            color: #565b75;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                if root.active-tab == 1: HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        background: #1f2030;
                        border-radius: 8px;
                        horizontal-stretch: 4;
                        VerticalLayout {
                            padding: 6px;
                            HorizontalLayout {
                                height: 34px;
                                spacing: 8px;
                                Text {
                                    text: "Saved Playlists (" + root.library-count + ")";
                                    color: #6c7393;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                            ListView {
                                for r[i] in root.library-rows: LibraryListRow {
                                    item: r;
                                    selected: i == root.library-selected;
                                    select => { root.select-library-item(i); }
                                    activate => { root.activate-library-item(i); }
                                    toggle-fav => { root.toggle-favorite(i); }
                                    remove => { root.remove-library-entry(i); }
                                }
                            }
                            if root.library-rows.length == 0: Text {
                                text: "Empty. Paste a YT/Bilibili playlist URL above, or play a track to seed Unsaved.";
                                color: #565b75;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                        }
                    }
                    Rectangle {
                        background: #1f2030;
                        border-radius: 8px;
                        horizontal-stretch: 6;
                        VerticalLayout {
                            padding: 6px;
                            HorizontalLayout {
                                height: 34px;
                                spacing: 8px;
                                Text {
                                    text: "Tracks · " + root.active-playlist-title
                                        + (root.is-loading-playlist ? " (loading…)"
                                            : " (" + root.tracks-count + ")");
                                    color: #6c7393;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                IconButton {
                                    label: "Save as…";
                                    button-width: 86px;
                                    clicked => {
                                        root.save-dialog-default = root.active-playlist-title == "Unsaved"
                                            ? ""
                                            : root.active-playlist-title;
                                        root.show-save-dialog = true;
                                    }
                                }
                            }
                            ListView {
                                for r[i] in root.tracks: TrackListRow {
                                item: r;
                                selected: i == root.tracks-selected;
                                show-remove: true;
                                select => { root.select-track(i); }
                                play => { root.play-track(i); }
                                remove => { root.remove-track(i); }
                            }
                        }
                        }
                    }
                }

                if root.active-tab == 2: Rectangle {
                    background: #1f2030;
                    border-radius: 8px;
                    VerticalLayout {
                        padding: 6px;
                        HorizontalLayout {
                            height: 34px;
                            spacing: 8px;
                                Text {
                                    text: root.is-scanning-local
                                    ? "Local files · scanning"
                                    : "Local files · " + root.local-count + " tracks";
                                color: #6c7393;
                                font-size: 12px;
                                font-weight: 600;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                        }
                        ListView {
                            for r[i] in root.local-tracks: TrackListRow {
                                item: r;
                                selected: i == root.local-selected;
                                show-add: true;
                                select => { root.select-local(i); }
                                play => { root.play-local(i); }
                                add => { root.add-local-to-playlist(i); }
                            }
                        }
                    }
                }
            }
        }

        if root.show-captions: Rectangle {
            background: #16171f;
            height: 56px;
            border-width: 1px;
            border-color: #2a2c3e;
            HorizontalLayout {
                padding: 8px;
                spacing: 10px;
                Text {
                    text: root.caption-status-label;
                    color: #565b75;
                    font-size: 11px;
                    width: 120px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.caption-text == "" ? "(no caption at this time)" : root.caption-text;
                    color: #c0caf5;
                    font-size: 14px;
                    vertical-alignment: center;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                }
            }
        }

        Rectangle {
            background: #16171f;
            height: 110px;
            border-width: 1px;
            border-color: #2a2c3e;
            VerticalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 4px;
                HorizontalLayout {
                    spacing: 10px;
                    height: 42px;
                    Text {
                        text: root.is-paused ? "⏸" : "▶";
                        color: #9ece6a;
                        font-size: 16px;
                        vertical-alignment: center;
                        width: 22px;
                    }
                    Text {
                        text: root.has-current
                            ? root.current-title
                            : "(nothing playing — pick a track and press play)";
                        color: #c0caf5;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: root.has-current ? " — " + root.current-uploader : "";
                        color: #6c7393;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    Text {
                        text: root.has-current
                            ? "from " + root.current-source-label
                            : "";
                        color: #565b75;
                        font-size: 11px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    Text {
                        text: root.position-str + " / " + root.duration-str;
                        color: #6c7393;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    padding-top: 4px;
                    padding-bottom: 4px;
                    height: 48px;
                    IconButton {
                        label: "⏮";
                        button-width: 36px;
                        clicked => { root.prev-track(); }
                    }
                    IconButton {
                        label: root.is-paused ? "▶" : "⏸";
                        button-width: 48px;
                        primary: true;
                        clicked => { root.toggle-pause(); }
                    }
                    IconButton {
                        label: "⏭";
                        button-width: 36px;
                        clicked => { root.next-track(); }
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 20px;
                        background: #2a2c3e;
                        border-radius: 10px;
                        Rectangle {
                            x: 0;
                            y: 0;
                            height: parent.height;
                            width: parent.width * root.playback-ratio;
                            background: #7aa2f7;
                            border-radius: 10px;
                        }
                        TouchArea {
                            clicked => {
                                root.seek-absolute(self.mouse-x / parent.width);
                            }
                        }
                    }
                    Text {
                        text: root.volume + "%";
                        color: #6c7393;
                        font-size: 11px;
                        vertical-alignment: center;
                        width: 36px;
                    }
                    Slider {
                        minimum: 0;
                        maximum: 100;
                        value: root.volume;
                        width: 90px;
                        changed(v) => {
                            root.set-volume(v);
                        }
                    }
                    IconButton {
                        label: "Loop: " + root.loop-mode-label;
                        button-width: 78px;
                        clicked => { root.cycle-loop(); }
                    }
                    IconButton {
                        label: root.shuffle-on ? "Shuffle on" : "Shuffle";
                        button-width: 78px;
                        clicked => { root.toggle-shuffle(); }
                    }
                    IconButton {
                        label: root.show-captions ? "CC on" : "CC";
                        button-width: 50px;
                        clicked => { root.toggle-captions(); }
                    }
                }
            }
        }

        Rectangle {
            background: #16171f;
            height: 22px;
            border-width: 0px;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                Text {
                    text: root.status-text;
                    color: #6c7393;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
    }

    if root.show-help: Rectangle {
        background: #00000080;
        TouchArea {
            clicked => { root.toggle-help(); }
        }
        Rectangle {
            width: 600px;
            height: 480px;
            background: #1f2030;
            border-radius: 10px;
            border-width: 1px;
            border-color: #3a3c52;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            VerticalLayout {
                padding: 20px;
                spacing: 8px;
                Text {
                    text: "ytmtui — quick reference";
                    color: #c0caf5;
                    font-size: 16px;
                    font-weight: 700;
                }
                Text {
                    text: "Search bar: type a query and press Enter. Prefix with #Y / #B / #H to scope to YouTube, Bilibili, or local files only.";
                    color: #6c7393;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Text {
                    text: "Open file/folder: absolute or ~/relative path. Folders are scanned up to 4 levels deep.";
                    color: #6c7393;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Text {
                    text: "Playlist URL: paste a YouTube or Bilibili playlist URL to load it into the Library.";
                    color: #6c7393;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Text {
                    text: "Single-click a row to select it. Double-click a track to play it or a playlist to open it. Row actions appear on the right and change by list.";
                    color: #6c7393;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Text {
                    text: "Click on the progress bar to seek to that position. Use the slider in the now-playing card for volume.";
                    color: #6c7393;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    alignment: end;
                    IconButton {
                        label: "Close";
                        clicked => { root.toggle-help(); }
                    }
                }
            }
        }
    }

    if root.show-params: Rectangle {
        background: #00000080;
        TouchArea {
            clicked => { root.toggle-params(); }
        }
        Rectangle {
            width: 480px;
            height: 320px;
            background: #1f2030;
            border-radius: 10px;
            border-width: 1px;
            border-color: #3a3c52;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text {
                    text: "Parameters";
                    color: #c0caf5;
                    font-size: 16px;
                    font-weight: 700;
                }
                HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: "Progress cursor";
                        color: #6c7393;
                        font-size: 13px;
                        vertical-alignment: center;
                        width: 140px;
                    }
                    IconButton {
                        label: "◀";
                        clicked => { root.cycle-sprite(-1); }
                    }
                    Text {
                        text: root.sprite-name + "  " + root.sprite-preview;
                        color: #c0caf5;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        horizontal-stretch: 1;
                    }
                    IconButton {
                        label: "▶";
                        clicked => { root.cycle-sprite(1); }
                    }
                    Text {
                        text: "(" + (root.sprite-index + 1) + "/" + root.sprite-total + ")";
                        color: #565b75;
                        font-size: 11px;
                        vertical-alignment: center;
                        width: 50px;
                    }
                }
                HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: "CC language";
                        color: #6c7393;
                        font-size: 13px;
                        vertical-alignment: center;
                        width: 140px;
                    }
                    IconButton {
                        label: "◀";
                        clicked => { root.cycle-caption-lang(-1); }
                    }
                    Text {
                        text: root.caption-lang;
                        color: #c0caf5;
                        font-size: 13px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        horizontal-stretch: 1;
                    }
                    IconButton {
                        label: "▶";
                        clicked => { root.cycle-caption-lang(1); }
                    }
                    Text {
                        text: "(" + (root.caption-lang-index + 1) + "/" + root.caption-lang-total + ")";
                        color: #565b75;
                        font-size: 11px;
                        vertical-alignment: center;
                        width: 50px;
                    }
                }
                HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: "Show Stats";
                        color: #6c7393;
                        font-size: 13px;
                        vertical-alignment: center;
                        width: 140px;
                    }
                    IconButton {
                        label: "Nerd stats";
                        primary: true;
                        clicked => {
                            root.toggle-nerd();
                            root.toggle-params();
                        }
                    }
                }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    alignment: end;
                    IconButton {
                        label: "Close";
                        clicked => { root.toggle-params(); }
                    }
                }
            }
        }
    }

    if root.show-nerd: Rectangle {
        background: #00000080;
        TouchArea {
            clicked => { root.toggle-nerd(); }
        }
        Rectangle {
            width: 520px;
            height: 440px;
            background: #1f2030;
            border-radius: 10px;
            border-width: 1px;
            border-color: #3a3c52;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            VerticalLayout {
                padding: 20px;
                spacing: 6px;
                Text {
                    text: "Nerd stats";
                    color: #c0caf5;
                    font-size: 16px;
                    font-weight: 700;
                }
                Text { text: "ytmtui  v" + root.ytmtui-version; color: #c0caf5; font-size: 12px; }
                Text { text: "mpv     " + root.mpv-version; color: #c0caf5; font-size: 12px; }
                Text { text: "yt-dlp  " + root.ytdlp-version; color: #c0caf5; font-size: 12px; }
                Rectangle { height: 8px; }
                Text { text: "CPU  " + root.cpu-summary; color: #9ece6a; font-size: 12px; font-weight: 600; }
                Text { text: "RAM  " + root.ram-summary; color: #7aa2f7; font-size: 12px; font-weight: 600; }
                Rectangle { height: 8px; }
                Text { text: "codec       " + root.codec-label; color: #c0caf5; font-size: 12px; }
                Text { text: "bitrate     " + root.bitrate-label; color: #c0caf5; font-size: 12px; }
                Text { text: "sample-rate " + root.samplerate-label; color: #c0caf5; font-size: 12px; }
                Text { text: "channels    " + root.channels-label; color: #c0caf5; font-size: 12px; }
                Rectangle { height: 8px; }
                Text { text: "device  " + root.device-name; color: #c0caf5; font-size: 12px; }
                Text { text: "model   " + root.device-detail; color: #c0caf5; font-size: 12px; }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    alignment: end;
                    IconButton {
                        label: "Close";
                        clicked => { root.toggle-nerd(); }
                    }
                }
            }
        }
    }

    if root.show-file-dialog: Rectangle {
        background: #00000080;
        TouchArea {
            clicked => { root.show-file-dialog = false; }
        }
        Rectangle {
            width: 500px;
            height: 200px;
            background: #1f2030;
            border-radius: 10px;
            border-width: 1px;
            border-color: #3a3c52;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            VerticalLayout {
                padding: 20px;
                spacing: 10px;
                Text {
                    text: "Open File or Folder";
                    color: #c0caf5;
                    font-size: 16px;
                    font-weight: 700;
                }
                Text {
                    text: "Enter a path, or click Browse to pick a folder with the file explorer. Folders are scanned up to 4 levels deep.";
                    color: #6c7393;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                file-input := LineEdit {
                    placeholder-text: "/path/to/file or ~/folder";
                    accepted => {
                        root.open-file(self.text);
                        root.show-file-dialog = false;
                        self.text = "";
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    IconButton {
                        label: "Browse…";
                        clicked => {
                            root.browse-file();
                            root.show-file-dialog = false;
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    IconButton {
                        label: "Cancel";
                        clicked => { root.show-file-dialog = false; }
                    }
                    IconButton {
                        label: "Open";
                        primary: true;
                        clicked => {
                            root.open-file(file-input.text);
                            root.show-file-dialog = false;
                            file-input.text = "";
                        }
                    }
                }
            }
        }
    }

    if root.show-playlist-url-dialog: Rectangle {
        background: #00000080;
        TouchArea {
            clicked => { root.show-playlist-url-dialog = false; }
        }
        Rectangle {
            width: 500px;
            height: 200px;
            background: #1f2030;
            border-radius: 10px;
            border-width: 1px;
            border-color: #3a3c52;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            VerticalLayout {
                padding: 20px;
                spacing: 10px;
                Text {
                    text: "Load Playlist";
                    color: #c0caf5;
                    font-size: 16px;
                    font-weight: 700;
                }
                Text {
                    text: "Paste a YouTube or Bilibili playlist URL.";
                    color: #6c7393;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                url-input := LineEdit {
                    placeholder-text: "https://...";
                    accepted => {
                        root.open-playlist-url(self.text);
                        root.show-playlist-url-dialog = false;
                        self.text = "";
                    }
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    IconButton {
                        label: "Cancel";
                        clicked => { root.show-playlist-url-dialog = false; }
                    }
                    IconButton {
                        label: "Load";
                        primary: true;
                        clicked => {
                            root.open-playlist-url(url-input.text);
                            root.show-playlist-url-dialog = false;
                            url-input.text = "";
                        }
                    }
                }
            }
        }
    }

    if root.show-save-dialog: Rectangle {
        background: #00000080;
        TouchArea {
            clicked => { root.show-save-dialog = false; }
        }
        Rectangle {
            width: 420px;
            height: 180px;
            background: #1f2030;
            border-radius: 10px;
            border-width: 1px;
            border-color: #3a3c52;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            VerticalLayout {
                padding: 20px;
                spacing: 10px;
                Text {
                    text: "Save Unsaved playlist as";
                    color: #c0caf5;
                    font-size: 14px;
                    font-weight: 700;
                }
                Text {
                    text: "Same name overwrites the existing entry.";
                    color: #6c7393;
                    font-size: 11px;
                }
                save-input := LineEdit {
                    placeholder-text: "Playlist name";
                    text: root.save-dialog-default;
                    accepted => {
                        if (self.text != "") {
                            root.save-playlist(self.text);
                            root.show-save-dialog = false;
                        }
                    }
                }
                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;
                    IconButton {
                        label: "Cancel";
                        clicked => { root.show-save-dialog = false; }
                    }
                    IconButton {
                        label: "Save";
                        primary: true;
                        clicked => {
                            if (save-input.text != "") {
                                root.save-playlist(save-input.text);
                                root.show-save-dialog = false;
                            }
                        }
                    }
                }
            }
        }
    }
}
